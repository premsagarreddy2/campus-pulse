<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %></title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<nav class="navbar">
  <% if (org) { %>
    <a href="/<%= org.slug %>/events" class="logo">
      <% if (org.logo) { %>
        <img src="<%= org.logo %>" alt="<%= org.name %>" style="height:24px;width:24px;border-radius:6px;object-fit:cover;margin-right:6px;vertical-align:middle">
      <% } %>
      <%= org.name %>
    </a>
  <% } else { %>
    <a href="/" class="logo">campus<span>pulse</span></a>
  <% } %>

  <% if (user) { %>
  <div class="nav-right">
    <% if (org && userRole) { %>
      <span class="nav-user">
        <%= userRole === 'admin' ? '👑' : userRole === 'coordinator' ? '🎯' : '🎓' %>
        <%= user.name %>
      </span>
      <% if (userRole === 'student') { %>
        <a href="/<%= org.slug %>/events/my-events" class="nav-btn">My Events</a>
      <% } %>
      <% if (userRole === 'admin' || userRole === 'coordinator') { %>
        <a href="/<%= org.slug %>/events/new" class="nav-btn primary">+ Create Event</a>
      <% } %>
      <% if (userRole === 'admin') { %>
        <a href="/<%= org.slug %>/manage" class="nav-btn">⚙️ Manage</a>
      <% } %>
      <a href="/my-organizations" class="nav-btn" title="Switch Organization">🔄 Orgs</a>
    <% } else { %>
      <span class="nav-user"><%= user.name %></span>
      <a href="/my-organizations" class="nav-btn">My Organizations</a>
      <a href="/create-organization" class="nav-btn primary">+ Create Org</a>
    <% } %>
    <a href="/auth/logout" class="nav-btn danger">Logout</a>
  </div>
  <% } %>
</nav>

<% if (success && success.length) { %>
  <div class="flash flash-success"><%= success[0] %></div>
<% } %>
<% if (error && error.length) { %>
  <div class="flash flash-error"><%= error[0] %></div>
<% } %>
