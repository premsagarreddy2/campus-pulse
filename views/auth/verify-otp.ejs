<%- include('../partials/header') %>

  <div class="auth-page">
    <div class="auth-card">
      <div style="text-align:center;margin-bottom:1.5rem">
        <h2 class="auth-title">Verify your Email</h2>
        <p class="auth-sub">Enter the 6-digit OTP sent to <%= email %></p>
      </div>

      <form action="<%= org ? '/' + org.slug + '/auth/verify-otp' : '/auth/verify-otp' %>" method="POST">
        <input type="hidden" name="email" value="<%= email %>" />
        
        <div class="form-group">
          <label for="otp">One-Time Password (OTP)</label>
          <input type="text" id="otp" name="otp" placeholder="123456" required autocomplete="off" pattern="\d{6}" maxlength="6" style="text-align:center; letter-spacing:0.5rem; font-size:1.5rem; font-weight: bold;">
        </div>
        
        <div class="form-submit">
          <button type="submit" class="btn btn-primary" style="width: 100%;">Verify Account</button>
        </div>
      </form>

      <p class="form-link" style="margin-top: 1.5rem;">
        Didn't receive it?
        <a href="<%= org ? '/' + org.slug + '/auth/register' : '/auth/register' %>">Try registering again</a>
      </p>

    </div>
  </div>

  <%- include('../partials/footer') %>
