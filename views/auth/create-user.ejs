<%- include('../partials/header') %>

  <div class="form-container">
    <div class="form-card">
      <h1>👑 Create Staff Account</h1>
      <p>Create admin or coordinator accounts</p>

      <form action="/auth/admin/create-user" method="POST">
        <div class="form-group">
          <label>Full Name</label>
          <input type="text" name="name" placeholder="Staff member name" required>
        </div>
        <div class="form-group">
          <label>Email Address</label>
          <input type="email" name="email" placeholder="staff@college.edu" required>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Temporary Password</label>
            <input type="text" name="password" placeholder="Set initial password" required minlength="6">
          </div>
          <div class="form-group">
            <label>Role</label>
            <select name="role">
              <option value="coordinator">🎯 Coordinator</option>
              <option value="admin">👑 Admin</option>
            </select>
          </div>
        </div>
        <div class="form-submit">
          <button type="submit" class="btn btn-primary">Create Account</button>
        </div>
      </form>

      <div style="margin-top:1.5rem">
        <a href="/events" class="btn btn-outline">← Back to Events</a>
      </div>
    </div>
  </div>

  <%- include('../partials/footer') %>