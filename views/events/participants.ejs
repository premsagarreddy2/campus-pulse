<%- include('../partials/header') %>

  <div class="participants-container">
    <!-- Header -->
    <div style="margin-bottom:1.5rem">
      <a href="/events/<%= event._id %>" style="color:var(--muted);text-decoration:none;font-size:0.88rem">← Back to
        Event</a>
      <div
        style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:1rem;margin-top:1rem">
        <div>
          <h1 style="font-family:'Syne',sans-serif;font-size:1.75rem;font-weight:800">
            <%= event.title %>
          </h1>
          <div style="display:flex;gap:0.5rem;margin-top:0.6rem;flex-wrap:wrap">
            <span class="badge badge-<%= event.category %>">
              <%= event.category %>
            </span>
            <span class="badge badge-<%= event.status %>">
              <%= event.status %>
            </span>
          </div>
        </div>
        <a href="/events/<%= event._id %>/scan" class="btn btn-primary btn-sm"
          style="width:auto;background:linear-gradient(135deg,#6366f1,#8b5cf6);white-space:nowrap">
          📷 Scan Entry QR
        </a>
      </div>
    </div>

    <!-- Stats mini -->
    <div style="display:flex;gap:2rem;margin-bottom:2rem;flex-wrap:wrap">
      <div style="text-align:center">
        <div style="font-family:'Syne',sans-serif;font-size:2rem;font-weight:800;color:var(--accent)">
          <%= participants.length %>
        </div>
        <div style="font-size:0.78rem;color:var(--muted)">Registered</div>
      </div>
      <div style="text-align:center">
        <div style="font-family:'Syne',sans-serif;font-size:2rem;font-weight:800;color:var(--green)">
          <%= totalAttended %>
        </div>
        <div style="font-size:0.78rem;color:var(--muted)">Attended</div>
      </div>
      <div style="text-align:center">
        <div style="font-family:'Syne',sans-serif;font-size:2rem;font-weight:800;color:var(--yellow)">
          <%= participants.length - totalAttended %>
        </div>
        <div style="font-size:0.78rem;color:var(--muted)">Absent</div>
      </div>
      <div style="text-align:center">
        <div style="font-family:'Syne',sans-serif;font-size:2rem;font-weight:800;">
          <%= participants.length> 0 ? Math.round((totalAttended / participants.length) * 100) : 0 %>%
        </div>
        <div style="font-size:0.78rem;color:var(--muted)">Attendance Rate</div>
      </div>
    </div>

    <div
      style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;flex-wrap:wrap;gap:0.75rem">
      <h3 style="font-family:'Syne',sans-serif">Participant List</h3>
      <a href="/events/<%= event._id %>/qr" class="btn btn-primary btn-sm" style="width:auto">📱 Open QR Scanner</a>
    </div>

    <% if (participants.length===0) { %>
      <div class="empty-state">
        <div class="empty-icon">👥</div>
        <p>No registrations yet</p>
      </div>
      <% } else { %>
        <table>
          <thead>
            <tr>
              <th>#</th>
              <th>Name</th>
              <th>Email</th>
              <th style="text-align:center">Attended</th>
              <th style="text-align:center">Action</th>
            </tr>
          </thead>
          <tbody>
            <% participants.forEach((p, i)=> { %>
              <tr>
                <td style="color:var(--muted)">
                  <%= i + 1 %>
                </td>
                <td><strong>
                    <%= p.name %>
                  </strong></td>
                <td style="color:var(--muted)">
                  <%= p.email %>
                </td>
                <td style="text-align:center">
                  <% if (p.attended) { %>
                    <span class="attended-yes">✓ Present</span>
                    <% } else { %>
                      <span class="attended-no">—</span>
                      <% } %>
                </td>
                <td style="text-align:center">
                  <% if (!p.attended) { %>
                    <form action="/events/<%= event._id %>/manual-attend" method="POST" style="display:inline">
                      <input type="hidden" name="studentId" value="<%= p._id %>">
                      <button type="submit" class="btn btn-sm"
                        style="width:auto;background:rgba(34,197,94,0.12);color:var(--green);border:1px solid rgba(34,197,94,0.3)">Mark
                        Present</button>
                    </form>
                    <% } else { %>
                      <span style="font-size:0.78rem;color:var(--muted)">Done</span>
                      <% } %>
                </td>
              </tr>
              <% }) %>
          </tbody>
        </table>
        <% } %>
  </div>

  <%- include('../partials/footer') %>