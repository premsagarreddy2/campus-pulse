<%- include('../partials/header') %>

  <div class="detail-container">
    <a href="<%= basePath %>/events" style="color:var(--muted);text-decoration:none;font-size:0.88rem;">← Back to
      Events</a>

    <div class="detail-header" style="margin-top:1.25rem">
      <% if (event.image) { %>
        <div class="detail-img"><img src="<%= event.image %>" alt="<%= event.title %>"></div>
        <% } else { %>
          <div class="detail-img">
            <%= event.catEmoji %>
          </div>
          <% } %>

            <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:0.75rem">
              <span class="badge badge-<%= event.category %>">
                <%= event.catEmoji %>
                  <%= event.category %>
              </span>
              <span class="badge badge-<%= event.status %>">
                <%= event.status %>
              </span>
              <span class="badge badge-price"
                style="background: <%= event.isPaid ? 'var(--yellow)' : 'var(--green)' %>; color: #000">
                <%= event.isPaid ? '₹' + event.registrationFee : 'Free' %>
              </span>
            </div>
            <h1 class="detail-title">
              <%= event.title %>
            </h1>
            <p style="color:var(--muted);font-size:0.88rem">Created by <strong style="color:var(--text)">
                <%= event.createdBy.name %>
              </strong></p>
    </div>

    <div class="detail-body">
      <!-- Left: description + actions -->
      <div>
        <h3 style="font-family:'Syne',sans-serif;margin-bottom:0.75rem;font-size:1.1rem">About this Event</h3>
        <p class="detail-desc">
          <%= event.description %>
        </p>

        <% if (user && userRole==='student' ) { %>
          <% if (isRegistered) { %>
            <div
              style="background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.25);border-radius:12px;padding:1.25rem;margin-bottom:1rem">
              <p style="color:var(--green);font-weight:600;margin-bottom:0.4rem">✓ You're registered for this event!</p>
              <p style="color:var(--muted);font-size:0.85rem">Check My Events to see your attendance QR during the
                event.</p>
            </div>
            <a href="<%= basePath %>/events/my-events" class="btn btn-outline" style="width:auto">Go to My Events</a>
            <% } else if (event.status==='Completed' ) { %>
              <button class="btn btn-muted" style="width:auto" disabled>Event has ended</button>
              <% } else if (event.maxSeats> 0 && event.registeredStudents.length >= event.maxSeats) { %>
                <button class="btn btn-muted" style="width:auto" disabled>Event is Full</button>
                <% } else { %>
                  <% if (event.isPaid) { %>
                    <button class="btn btn-primary" id="payButton" style="width:auto;padding:0.7rem 2rem">Pay ₹<%=
                        event.registrationFee %> & Register →</button>
                    <% } else { %>
                      <form action="<%= basePath %>/events/<%= event._id %>/register" method="POST"
                        style="display:inline">
                        <button type="submit" class="btn btn-primary" style="width:auto;padding:0.7rem 2rem">Register
                          for this Event →</button>
                      </form>
                      <% } %>
                        <% } %>
                          <% } else if (user && (userRole==='admin' || userRole==='coordinator' )) { %>
                            <div class="btn-group" style="flex-wrap:wrap">
                              <a href="<%= basePath %>/events/<%= event._id %>/scan" class="btn btn-primary btn-sm"
                                style="width:auto;background:linear-gradient(135deg,#6366f1,#8b5cf6)">📷 Scan Entry
                                QR</a>
                              <a href="<%= basePath %>/events/<%= event._id %>/participants"
                                class="btn btn-outline btn-sm" style="width:auto">👥 Participants</a>
                              <a href="<%= basePath %>/events/<%= event._id %>/qr" class="btn btn-outline btn-sm"
                                style="width:auto">📱 Event QR</a>
                              <a href="<%= basePath %>/events/<%= event._id %>/edit" class="btn btn-outline btn-sm"
                                style="width:auto">✏️ Edit</a>
                              <form action="<%= basePath %>/events/<%= event._id %>?_method=DELETE" method="POST"
                                style="display:inline">
                                <button type="submit" class="btn btn-sm confirm-delete"
                                  style="width:auto;background:rgba(239,68,68,0.12);color:var(--red);border:1px solid rgba(239,68,68,0.3)">🗑️
                                  Delete</button>
                              </form>
                            </div>
                            <% } %>
      </div>

      <!-- Right: info card -->
      <div class="detail-info-card">
        <h3 style="font-family:'Syne',sans-serif;margin-bottom:1rem;font-size:1rem">Event Details</h3>

        <div class="info-row">
          <span class="icon">📅</span>
          <div>
            <div class="label">Date & Time</div>
            <div class="val">
              <%= new Date(event.date).toLocaleString('en-IN', {dateStyle:'full', timeStyle:'short'}) %>
            </div>
          </div>
        </div>
        <div class="info-row">
          <span class="icon">📍</span>
          <div>
            <div class="label">Venue</div>
            <div class="val">
              <%= event.venue %>
            </div>
          </div>
        </div>
        <div class="info-row">
          <span class="icon">⏱</span>
          <div>
            <div class="label">Duration</div>
            <div class="val">
              <%= event.durationHours %> hours
            </div>
          </div>
        </div>
        <div class="info-row">
          <span class="icon">🏷</span>
          <div>
            <div class="label">Category</div>
            <div class="val">
              <%= event.catEmoji %>
                <%= event.category %>
            </div>
          </div>
        </div>
        <div class="info-row">
          <span class="icon">👥</span>
          <div>
            <div class="label">Registrations</div>
            <div class="val">
              <%= event.registeredStudents.length %> registered
                <% if (event.maxSeats> 0) { %>
                  / <%= event.maxSeats %> seats
                    <% } else { %>
                      (unlimited)
                      <% } %>
            </div>
          </div>
        </div>

        <% if (event.maxSeats> 0) { %>
          <% const pct=Math.round((event.registeredStudents.length / event.maxSeats) * 100) %>
            <div class="seats-bar" style="margin-top:0.5rem">
              <div class="seats-fill"
                style="width:<%= pct %>%;background:<%= pct > 90 ? 'var(--red)' : pct > 60 ? 'var(--yellow)' : 'var(--accent)' %>">
              </div>
            </div>
            <% } %>
      </div>
    </div>
  </div>

  <% if (event.isPaid && user && userRole==='student' && !isRegistered && event.status !=='Completed' &&
    (event.maxSeats===0 || event.registeredStudents.length < event.maxSeats)) { %>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script>
      document.getElementById('payButton').onclick = async function (e) {
        e.preventDefault();
        try {
          const response = await fetch('<%= basePath %>/events/<%= event._id %>/create-order', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            }
          });
          const result = await response.json();

          if (!response.ok) {
            alert('Error: ' + result.error);
            return;
          }

          const options = {
            "key": result.key_id,
            "amount": result.order.amount,
            "currency": result.order.currency,
            "name": "<%= event.title %>",
            "description": "Registration Fee",
            "order_id": result.order.id,
            "handler": function (response) {
              const form = document.createElement('form');
              form.method = 'POST';
              form.action = '<%= basePath %>/events/<%= event._id %>/verify-payment';

              const pId = document.createElement('input');
              pId.type = 'hidden';
              pId.name = 'razorpay_payment_id';
              pId.value = response.razorpay_payment_id;

              const oId = document.createElement('input');
              oId.type = 'hidden';
              oId.name = 'razorpay_order_id';
              oId.value = response.razorpay_order_id;

              const sig = document.createElement('input');
              sig.type = 'hidden';
              sig.name = 'razorpay_signature';
              sig.value = response.razorpay_signature;

              form.appendChild(pId);
              form.appendChild(oId);
              form.appendChild(sig);
              document.body.appendChild(form);
              form.submit();
            },
            "prefill": {
              "name": "<%= user.name %>",
              "email": "<%= user.email %>"
            },
            "theme": {
              "color": "#6366f1"
            }
          };
          const rzp1 = new Razorpay(options);
          rzp1.on('payment.failed', function (response) {
            alert('Payment Failed! ' + response.error.description);
          });
          rzp1.open();
        } catch (error) {
          alert('Something went wrong. Please try again later.');
        }
      };
    </script>
    <% } %>

      <%- include('../partials/footer') %>