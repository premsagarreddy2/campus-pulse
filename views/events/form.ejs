<%- include('../partials/header') %>

<div class="form-container">
  <div class="form-card">
    <h1><%= event ? '✏️ Edit Event' : '🎉 Create New Event' %></h1>
    <p><%= event ? 'Update the details for this event' : 'Fill in the details to publish a new event' %></p>

    <form action="<%= formAction %>" method="<%= formMethod %>" enctype="multipart/form-data">

      <div class="form-group">
        <label>Event Title *</label>
        <input type="text" name="title" value="<%= event ? event.title : '' %>" placeholder="e.g. National Hackathon 2025" required>
      </div>

      <div class="form-group">
        <label>Description *</label>
        <textarea name="description" placeholder="What is this event about? Who should attend?" required><%= event ? event.description : '' %></textarea>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>Date & Time *</label>
          <input type="datetime-local" name="date"
            value="<%= event ? new Date(event.date).toISOString().slice(0,16) : '' %>" required>
        </div>
        <div class="form-group">
          <label>Duration (hours)</label>
          <input type="number" name="durationHours" value="<%= event ? event.durationHours : 2 %>" min="0.5" step="0.5">
        </div>
      </div>

      <div class="form-group">
        <label>Venue *</label>
        <input type="text" name="venue" value="<%= event ? event.venue : '' %>" placeholder="e.g. Seminar Hall A, Ground Floor" required>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>Category *</label>
          <select name="category">
            <% categories.forEach(cat => { %>
              <option value="<%= cat %>" <%= event && event.category === cat ? 'selected' : '' %>><%= cat %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>Max Seats (0 = unlimited)</label>
          <input type="number" name="maxSeats" value="<%= event ? event.maxSeats : 0 %>" min="0">
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>Registration Type *</label>
          <select name="isPaid" id="isPaidSelect" onchange="toggleFeeInput()">
            <option value="false" <%= event && !event.isPaid ? 'selected' : '' %>>Free</option>
            <option value="true" <%= event && event.isPaid ? 'selected' : '' %>>Paid</option>
          </select>
        </div>
        <div class="form-group" id="feeGroup" style="<%= event && event.isPaid ? '' : 'display:none;' %>">
          <label>Registration Fee (₹) *</label>
          <input type="number" name="registrationFee" id="registrationFee" value="<%= event ? event.registrationFee : 0 %>" min="0" step="1" <%= event && event.isPaid ? 'required' : '' %>>
        </div>
      </div>

      <div class="form-group">
        <label>Event Image (optional)</label>
        <input type="file" name="image" accept="image/*" style="color:var(--muted)">
        <% if (event && event.image) { %>
          <p style="font-size:0.78rem;color:var(--muted);margin-top:0.4rem">Current: <%= event.image %> — upload to replace</p>
        <% } %>
      </div>

      <div class="form-submit">
        <button type="submit" class="btn btn-primary"><%= event ? 'Save Changes' : 'Publish Event' %></button>
      </div>
    </form>

    <script>
      function toggleFeeInput() {
        const isPaid = document.getElementById('isPaidSelect').value === 'true';
        const feeGroup = document.getElementById('feeGroup');
        const feeInput = document.getElementById('registrationFee');
        if (isPaid) {
          feeGroup.style.display = 'block';
          feeInput.required = true;
        } else {
          feeGroup.style.display = 'none';
          feeInput.required = false;
          feeInput.value = 0;
        }
      }
    </script>

    <div style="margin-top:1rem">
      <a href="<%= basePath %>/events" class="btn btn-outline">← Cancel</a>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
